{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": ["lib/**/*.js"],
  "exclude": ["node_modules", ".next", "coverage", "lib/measurers/**"]
}
