# Travel app environment — the contract. Copy to .env.local and fill in.
# Sections + naming follow the family platform env/config standard
# (~/src/schubert-family/docs/env-and-config-standard.md). Every key here is
# also validated at boot by lib/env.js (#88): missing required → refuse to start.

# ── App ─────────────────────────────────────────────────────────────────────
# NODE_ENV is set by the runtime (Next/Vercel); listed for completeness.
# NEXT_PUBLIC_APP_URL is this app's own URL (travel.schubertfamily.com in prod).
# NEXT_PUBLIC_HUB_URL is the family hub's URL — REQUIRED. Interim Vercel default,
# becomes https://schubertfamily.com at the cutover.
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_HUB_URL=

# ── Supabase ────────────────────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API.
# Publishable key is safe to expose to the browser (gated by RLS).
# Secret key (service_role) is SERVER ONLY — never NEXT_PUBLIC_, never bundled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ── Integrations ────────────────────────────────────────────────────────────
# Hero-image search; measurement pipeline. Optional at boot — each route/script
# that uses one fails loud on its own when the value is missing.
UNSPLASH_ACCESS_KEY=
CENSUS_API_KEY=
WALKSCORE_API_KEY=
GOOGLE_PLACES_API_KEY=

# ── Local/dev only (never set in production) ────────────────────────────────
# /api/dev-login auth bypass — hard-disabled when NODE_ENV=production.
# Mints a session via SUPABASE_SECRET_KEY for this email (#87).
DEV_LOGIN_EMAIL=

# Local Overpass for OSM POI fetches (US-only extract). Defaults to the
# project-local Docker (http://localhost:12345/api/interpreter); set to override.
OVERPASS_URL=

# ── In the macOS Keychain, NOT here ─────────────────────────────────────────
# Direct Postgres password used by the local measurement pipeline
# (lib/measurers/_db.js). Account: livability-scout / service: supabase-db-password.
# See features/deployment.md "Secrets: macOS Keychain vs Vercel".
